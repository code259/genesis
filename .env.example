ANTHROPIC_API_KEY=your_key       # Tier 2
OPENAI_API_KEY=your_key          # Tier 2 cross-check
GROQ_API_KEY=your_key            # Tier 1 primary routing
GROQ_API_KEY_2=your_backup_key   # Optional Groq failover key
GROQ_API_KEY_3=your_backup_key   # Optional Groq failover key
TOGETHER_API_KEY=your_key        # Optional alternative OpenAI-compatible provider
GOOGLE_AI_API_KEY=your_key       # Tier 1
# Tier 0 (Ollama) needs no key — runs locally
# Tier 1 = Groq + OpenAI mini cross-check
# Tier 2 = Anthropic + OpenAI
MODEL_TIER=1
GENESIS_WORKER_MAX_STEPS=6
